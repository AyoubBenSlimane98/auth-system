# APP
NODE_ENV=production
APP_PORT=3002
BACKEND_URL=https://auth-system-backend.com
CROSS_ORIGIN=https://auth-system-frontend.app

# DATA
DATABASE_URL="postgresql://postgres:postgres@db:5432/auth_db"
REDIS_URL="rediss://default:sdsdfvYQ@super-haddock-102146.upstash.io:6379"

# FRONTEND APP
APP_FRONTEND_URL=https://auth-system-frontend.app
APP_REDIRECT_FRONTEND=${APP_FRONTEND_URL}/home

# ARGON
ARGON2_SECRET="your_argon2_secret"

# SENDGRID
SENDGRID_API_KEY="your_sendgrid_api_key"
SENDGRID_FROM_EMAIL="your_email@example.com"

# JWT AUTH (Access + Refresh)
JWT_JWT_AUTH_PRIVATE_KEY="-----BEGIN PRIVATE------"
JWT_JWT_AUTH_PUBLIC_KEY="------BEGIN PUBLIC-------"
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# JWT EMAIL VERIFICATION
JWT_EMAIL_PRIVATE_KEY="-----BEGIN PRIVATE------"
JWT_EMAIL_PUBLIC_KEY="------BEGIN PUBLIC-------"
EMAIL_TOKEN_EXPIRES_IN=10m

# JWT RESET PASSWORD
JWT_RESET_PRIVATE_KEY="-----BEGIN PRIVATE------"
JWT_RESET_PUBLIC_KEY="------BEGIN PUBLIC-------"
RESET_TOKEN_EXPIRES_IN=10m

# GOOGLE AUTH
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL=${BACKEND_URL}/auth/google/callback

#TWITTER
TWITTER_CLIENT_ID="your_twitter_client_id"
TWITTER_CLIENT_SECRET="your_twitter_client_secret"
TWITTER_CALLBACK_URL=${BACKEND_URL}/auth/twitter/callback
