# APP
NODE_ENV=development
APP_PORT=3002
DATABASE_URL=postgresql://postgres:postgres@db:5432/auth_db
BACKEND_URL=http://localhost:3002

# FRONTEND APP
APP_FRONTEND_URL=http://localhost:3000
APP_REDIRECT_FRONTEND=${APP_FRONTEND_URL}/home
CROSS_ORIGIN=${APP_FRONTEND_URL}
# ARGON
ARGON2_SECRET=bd7ece9FVDFSVDFeecc0dXCSDF65ff1c3f93dd03dsfvdbc97BDFGBFGf

# SENDGRID
SENDGRID_API_KEY="your_sendgrid_api_key"
SENDGRID_FROM_EMAIL="your_email@example.com"

# JWT AUTH (Access + Refresh)
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# JWT EMAIL VERIFICATION
EMAIL_TOKEN_EXPIRES_IN=10m

# JWT RESET PASSWORD
RESET_TOKEN_EXPIRES_IN=10m

# GOOGLE AUTH
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL=${BACKEND_URL}/auth/google/callback

#TWITTER
TWITTER_CLIENT_ID="your_twitter_client_id"
TWITTER_CLIENT_SECRET="your_twitter_client_secret"
TWITTER_CALLBACK_URL=${BACKEND_URL}/auth/twitter/callback

#REDIS
REDIS_HOST=redis
REDIS_PORT=6379
