# APP
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@db:5432/auth_db"
APP_PORT=3002

# FRONTEND APP
APP_REDIRECT_FRONTEND=my-domain-app/home
APP_FRONTEND_URL=my-domain-app

# ARGON
ARGON2_SECRET="your_argon2_secret"

# SENDGRID
SENDGRID_API_KEY="your_sendgrid_api_key"
SENDGRID_FROM_EMAIL="your_email@example.com"

# JWT AUTH (Access + Refresh)
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# JWT EMAIL VERIFICATION
EMAIL_TOKEN_EXPIRES_IN=10m

# JWT RESET PASSWORD
RESET_TOKEN_EXPIRES_IN=10m

# GOOGLE AUTH
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="my-domain-app/auth/google/callback"

# TWITTER
TWITTER_CONSUMER_KEY="your_twitter_consumer_key"
TWITTER_CONSUMER_SECRET="your_twitter_consumer_secret"
TWITTER_CALLBACK_URL="my-domain-app/auth/twitter/callback"

#REDIS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=StroangePassword
